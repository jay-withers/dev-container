{
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "github.vscode-github-actions",
        "redhat.vscode-yaml",
        "timonwong.shellcheck",
        "DavidAnson.vscode-markdownlint",
        "eamodio.gitlens",
        "anthropic.claude-code"
      ],
      "settings": {
        "editor.formatOnSave": true
      }
    }
  },
  "image": "ghcr.io/jay-withers/dev-container/base:latest",
  "name": "Dev Container Images",
  "postCreateCommand": "pre-commit install --config config/.pre-commit-config.yaml",
  "remoteUser": "vscode",
  "runArgs": [
    "--security-opt=no-new-privileges:true"
  ]
}
