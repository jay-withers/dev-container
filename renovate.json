{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "autoApprove": true,
  "automerge": true,
  "automergeStrategy": "squash",
  "automergeType": "pr",
  "customManagers": [
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "terraform-linters/tflint",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG TFLINT_URL=\"https://github\\.com/terraform-linters/tflint/releases/download/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "terraform-linters/tflint",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "bridgecrewio/checkov",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG CHECKOV_URL=\"https://github\\.com/bridgecrewio/checkov/releases/download/(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "bridgecrewio/checkov",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "terraform-docs/terraform-docs",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG TERRAFORM_DOCS_URL=\"https://github\\.com/terraform-docs/terraform-docs/releases/download/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "terraform-docs/terraform-docs",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "pre-commit/pre-commit",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG PRE_COMMIT_URL=\"https://github\\.com/pre-commit/pre-commit/releases/download/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "pre-commit/pre-commit",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "node-version",
      "depNameTemplate": "node",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG NODE_URL=\"https://nodejs\\.org/dist/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "versioningTemplate": "node"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "kubernetes/kubernetes",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG KUBECTL_URL=\"https://dl\\.k8s\\.io/release/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "kubernetes/kubernetes",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "helm/helm",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG HELM_URL=\"https://get\\.helm\\.sh/helm-v(?<currentValue>[^-]+)-[^\"]+\""
      ],
      "packageNameTemplate": "helm/helm",
      "versioningTemplate": "semver"
    },
    {
      "customType": "regex",
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "derailed/k9s",
      "fileMatch": [
        "^\\.devcontainer/Dockerfile$"
      ],
      "matchStrings": [
        "ARG K9S_URL=\"https://github\\.com/derailed/k9s/releases/download/v(?<currentValue>[^/]+)/[^\"]+\""
      ],
      "packageNameTemplate": "derailed/k9s",
      "versioningTemplate": "semver"
    }
  ],
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "GitHub Actions",
      "matchManagers": [
        "github-actions"
      ]
    },
    {
      "groupName": "pre-commit hooks",
      "matchManagers": [
        "pre-commit"
      ]
    },
    {
      "groupName": "dev container tools",
      "matchFiles": [
        ".devcontainer/Dockerfile"
      ]
    }
  ],
  "platformAutomerge": true,
  "pre-commit": {
    "fileMatch": [
      "(^|/)config/\\.pre-commit-config\\.yaml$"
    ]
  },
  "schedule": [
    "once a week"
  ]
}
